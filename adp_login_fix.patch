+  const seen = new Set();
+
+  for (const envPath of candidates) {
+    if (seen.has(envPath)) continue;
+    seen.add(envPath);
+    if (!fsSync.existsSync(envPath)) continue;
+    dotenv.config({ path: envPath, override: false });
