+# Start here. Copy this file to .env and fill in values locally.
+# Do not commit .env, .auth, captures, or parsed_schedule.
+
+ADP_URL=https://my.adp.com/#/time
+ADP_USERNAME=your_username_here
+ADP_PASSWORD=your_password_here
+
+# Leave false while developing. Headless usually only works after the session is already trusted.
+ADP_HEADLESS=false
+
+# true = temporary incognito browser context. No cookies/session saved after the run.
+# false = persistent local profile in ADP_PROFILE_DIR, which may stay logged in between runs.
+ADP_INCOGNITO=true
+
+# How long to wait for the ADP login form to appear after redirects/JS load.
+ADP_LOGIN_TIMEOUT_MS=45000
+
+# Optional. If clicking the tile is unreliable, paste the final Team Schedule URL here after one manual run.
+TEAM_SCHEDULE_URL=
+TEAM_SCHEDULE_TEXT=Team Schedule
+
+# Where local browser session/cookies and outputs are stored.
+ADP_PROFILE_DIR=.auth/adp-browser-profile
+OUTPUT_DIR=captures
+PARSED_OUT_DIR=parsed_schedule
+
+# Calendar settings used by the parser for generated employee ICS files.
+CALENDAR_TIMEZONE=America/Vancouver
+CALENDAR_LOCATION=
+CALENDAR_ALARMS=1440,180,60
